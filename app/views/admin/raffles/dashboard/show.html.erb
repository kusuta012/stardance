<% content_for :title, "Raffle admin" %>
<%= render "admin/raffles/shared/nav" %>

<h1>Raffle, overview</h1>

<ul>
  <li>Current week:
    <% if @current_week %>
      Week <%= @current_week.number %> of 16, <%= @current_week.prize %>
    <% else %>
      none active
    <% end %>
  </li>
  <li>Participants: <%= @participant_count %></li>
  <li>Verified referrals (all time): <%= @verified_count %></li>
  <li>Pending referrals: <%= @pending_count %></li>
</ul>

<% if @current_week %>
  <p>
    <%= button_to "Close week #{@current_week.number} & open next",
                  close_admin_raffles_week_path(@current_week), method: :post,
                  data: { turbo_confirm: "Archive week #{@current_week.number} and open the next week? Pending referrals carry over." } %>
  </p>
<% end %>

<h2>Leaderboard, this week</h2>
<% if @leaderboard.any? %>
  <table>
    <thead><tr><th>#</th><th>Participant</th><th>Code</th><th>Tickets</th></tr></thead>
    <tbody>
      <% @leaderboard.each_with_index do |(participant, tickets), i| %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= link_to participant.github_login, admin_raffles_participant_path(participant) %></td>
          <td><code><%= participant.code %></code></td>
          <td><%= tickets %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No tickets credited this week yet.</p>
<% end %>
